    {
      "parameters": {
        "jsCode": "// Aggregate Health Check Results\n// Collects outputs from all three API check nodes and builds a health report.\n\nconst now = new Date().toISOString();\n\n// --- Notion Check ---\nlet notion_status = 'OK';\nlet notion_error = null;\ntry {\n  const notionData = $('Check Notion API').first();\n  if (notionData.json.error || notionData.json.errorMessage) {\n    notion_status = 'FAIL';\n    notion_error = notionData.json.errorMessage || notionData.json.error || 'Unknown Notion error';\n  }\n} catch (e) {\n  notion_status = 'FAIL';\n  notion_error = e.message || 'Could not retrieve Notion check result';\n}\n\n// --- Gmail Check ---\nlet gmail_status = 'OK';\nlet gmail_error = null;\ntry {\n  const gmailData = $('Check Gmail API').first();\n  if (gmailData.json.error || gmailData.json.errorMessage) {\n    gmail_status = 'FAIL';\n    gmail_error = gmailData.json.errorMessage || gmailData.json.error || 'Unknown Gmail error';\n  }\n} catch (e) {\n  gmail_status = 'FAIL';\n  gmail_error = e.message || 'Could not retrieve Gmail check result';\n}\n\n// --- Slack Check ---\nlet slack_status = 'OK';\nlet slack_error = null;\ntry {\n  const slackData = $('Check Slack API').first();\n  if (slackData.json.error || slackData.json.errorMessage) {\n    slack_status = 'FAIL';\n    slack_error = slackData.json.errorMessage || slackData.json.error || 'Unknown Slack error';\n  }\n} catch (e) {\n  slack_status = 'FAIL';\n  slack_error = e.message || 'Could not retrieve Slack check result';\n}\n\n// --- Build report ---\nconst all_ok = (notion_status === 'OK' && gmail_status === 'OK' && slack_status === 'OK');\n\nconst failed_services = [];\nif (notion_status === 'FAIL') failed_services.push('Notion');\nif (gmail_status === 'FAIL') failed_services.push('Gmail');\nif (slack_status === 'FAIL') failed_services.push('Slack');\n\nconst status_summary = all_ok\n  ? 'ALL_OK - Todos los servicios operativos'\n  : `DEGRADED - Servicios con falla: ${failed_services.join(', ')}`;\n\nreturn [{\n  json: {\n    notion_status,\n    notion_error,\n    gmail_status,\n    gmail_error,\n    slack_status,\n    slack_error,\n    all_ok,\n    failed_services,\n    status_summary,\n    timestamp: now,\n    workflow_id: 'FTC-WF-010',\n    workflow_name: 'Health Check del Sistema'\n  }\n}];"
      },
      "id": "code-aggregate",
      "name": "Code - Agregar Resultados",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "any-check-failed",
              "leftValue": "={{ $json.all_ok }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEqual"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-any-failed",
      "name": "IF - Algun Check Fallo?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1200,
        300
      ]
    },
    {
      "parameters": {
        "sendTo": "={{ $env.EMAIL_FROM }}",
        "subject": "=\u26a0\ufe0f Health Check Failed - {{ $json.failed_services.join(', ') }} - FinteChile",
        "message": "=<html><body style=\"font-family: Arial, sans-serif; color: #333;\"><div style=\"max-width: 600px; margin: 0 auto;\"><div style=\"background-color: #c0392b; padding: 20px; text-align: center;\"><h1 style=\"color: #ffffff; margin: 0;\">\u26a0\ufe0f Health Check FAILED</h1></div><div style=\"padding: 30px; background-color: #f9f9f9;\"><h2>Reporte de Salud del Sistema - FinteChile</h2><p><strong>Timestamp:</strong> {{ $json.timestamp }}</p><p><strong>Estado General:</strong> <span style=\"color: #c0392b; font-weight: bold;\">{{ $json.status_summary }}</span></p><h3>Detalle por Servicio:</h3><table style=\"border-collapse: collapse; width: 100%;\" border=\"1\" cellpadding=\"8\"><tr style=\"background-color: #ecf0f1;\"><th>Servicio</th><th>Estado</th><th>Error</th></tr><tr><td>Notion API</td><td style=\"color: {{ $json.notion_status === 'OK' ? '#27ae60' : '#c0392b' }}; font-weight: bold;\">{{ $json.notion_status }}</td><td>{{ $json.notion_error || 'N/A' }}</td></tr><tr><td>Gmail API</td><td style=\"color: {{ $json.gmail_status === 'OK' ? '#27ae60' : '#c0392b' }}; font-weight: bold;\">{{ $json.gmail_status }}</td><td>{{ $json.gmail_error || 'N/A' }}</td></tr><tr><td>Slack API</td><td style=\"color: {{ $json.slack_status === 'OK' ? '#27ae60' : '#c0392b' }}; font-weight: bold;\">{{ $json.slack_status }}</td><td>{{ $json.slack_error || 'N/A' }}</td></tr></table><h3>Accion requerida:</h3><p>Revise los servicios con estado <strong>FAIL</strong> y verifique las credenciales, permisos y disponibilidad de la API.</p></div><div style=\"background-color: #eeeeee; padding: 15px; text-align: center; font-size: 12px;\"><p>FinteChile - Sistema de Monitoreo Automatizado</p><p>Workflow: FTC-WF-010 | Health Check del Sistema</p></div></div></body></html>",
        "options": {
          "senderName": "FinteChile Health Monitor",
          "replyTo": "={{ $env.EMAIL_FROM }}"
        }
      },
