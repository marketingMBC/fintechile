    {
      "parameters": {
        "jsCode": "// Evaluate membership status from Notion query result\nconst registrationData = $('Validar y Normalizar Datos').item.json;\nconst empresaResults = $input.all();\n\nlet is_member = false;\nlet member_tier = 'No Socio';\nlet empresa_notion_id = null;\nlet discount_applied = false;\nlet discount_percentage = 0;\n\nif (empresaResults.length > 0) {\n  const empresa = empresaResults[0].json;\n  const estado = empresa.properties?.Estado?.select?.name || \n                 empresa.properties?.Estado?.status?.name || '';\n  \n  if (estado === 'Activo') {\n    is_member = true;\n    empresa_notion_id = empresa.id;\n    \n    // Determine tier and discount\n    const tier = empresa.properties?.Tier?.select?.name || \n                 empresa.properties?.Categoria?.select?.name || 'Basico';\n    member_tier = tier;\n    \n    switch (tier) {\n      case 'Premium':\n      case 'Oro':\n        discount_percentage = 30;\n        break;\n      case 'Estandar':\n      case 'Plata':\n        discount_percentage = 20;\n        break;\n      default:\n        discount_percentage = 10;\n        break;\n    }\n    discount_applied = true;\n  }\n}\n\nreturn {\n  json: {\n    ...registrationData,\n    is_member,\n    member_tier,\n    empresa_notion_id,\n    discount_applied,\n    discount_percentage\n  }\n};"
      },
      "id": "code-evaluate-membership",
      "name": "Evaluar Membresia",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        300
      ]
    },
