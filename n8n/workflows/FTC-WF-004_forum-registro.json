      "parameters": {
        "jsCode": "// Prepare email content based on registration data\nconst data = $('Merge: Unificar Registro').item.json;\n\nlet discountSection = '';\nif (data.discount_applied) {\n  discountSection = `\n    <tr>\n      <td style=\"padding: 12px 16px; background-color: #e8f5e9; border-radius: 8px;\">\n        <strong>Descuento Socio Aplicado</strong><br>\n        Como socio ${data.member_tier} de FinteChile, se ha aplicado un <strong>${data.discount_percentage}% de descuento</strong> a tu registro.\n      </td>\n    </tr>\n    <tr><td style=\"padding: 8px 0;\"></td></tr>`;\n}\n\nconst emailBody = `\n<div style=\"font-family: 'Helvetica Neue', Arial, sans-serif; max-width: 600px; margin: 0 auto; color: #333;\">\n  <div style=\"background: linear-gradient(135deg, #1a237e 0%, #0d47a1 100%); padding: 32px; text-align: center; border-radius: 12px 12px 0 0;\">\n    <h1 style=\"color: #ffffff; margin: 0; font-size: 24px;\">Chile Fintech Forum 2026</h1>\n    <p style=\"color: #bbdefb; margin: 8px 0 0 0; font-size: 14px;\">Confirmacion de Registro</p>\n  </div>\n  \n  <div style=\"padding: 32px; background-color: #ffffff; border: 1px solid #e0e0e0; border-top: none;\">\n    <p>Estimado/a <strong>${data.nombre}</strong>,</p>\n    <p>Tu registro al Chile Fintech Forum 2026 ha sido confirmado exitosamente.</p>\n    \n    <table style=\"width: 100%; border-collapse: collapse; margin: 24px 0;\">\n      <tr>\n        <td style=\"padding: 12px 16px; background-color: #f5f5f5; border-radius: 8px;\">\n          <strong>Numero de Confirmacion</strong><br>\n          <span style=\"font-size: 20px; color: #1a237e; font-weight: bold;\">${data.confirmation_number}</span>\n        </td>\n      </tr>\n      <tr><td style=\"padding: 8px 0;\"></td></tr>\n      ${discountSection}\n      <tr>\n        <td style=\"padding: 12px 16px; background-color: #f5f5f5; border-radius: 8px;\">\n          <table style=\"width: 100%;\">\n            <tr><td><strong>Evento:</strong></td><td>${data.event_name}</td></tr>\n            <tr><td><strong>Fecha:</strong></td><td>15 de Junio, 2026</td></tr>\n            <tr><td><strong>Horario:</strong></td><td>09:00 - 18:00 hrs</td></tr>\n            <tr><td><strong>Lugar:</strong></td><td>Santiago, Chile</td></tr>\n            <tr><td><strong>Ticket:</strong></td><td>${data.ticket_label}</td></tr>\n          </table>\n        </td>\n      </tr>\n      <tr><td style=\"padding: 8px 0;\"></td></tr>\n      <tr>\n        <td style=\"padding: 12px 16px; background-color: #f5f5f5; border-radius: 8px;\">\n          <table style=\"width: 100%;\">\n            <tr><td><strong>Nombre:</strong></td><td>${data.nombre}</td></tr>\n            <tr><td><strong>Email:</strong></td><td>${data.email}</td></tr>\n            <tr><td><strong>Empresa:</strong></td><td>${data.empresa}</td></tr>\n            <tr><td><strong>Cargo:</strong></td><td>${data.cargo}</td></tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n    \n    <p style=\"font-size: 13px; color: #757575;\">Este correo es una confirmacion automatica. Guarda tu numero de confirmacion para presentarlo el dia del evento.</p>\n  </div>\n  \n  <div style=\"padding: 16px; text-align: center; background-color: #f5f5f5; border-radius: 0 0 12px 12px; border: 1px solid #e0e0e0; border-top: none;\">\n    <p style=\"margin: 0; font-size: 12px; color: #9e9e9e;\">FinteChile - Asociacion Fintech de Chile</p>\n  </div>\n</div>`;\n\nreturn {\n  json: {\n    ...data,\n    email_subject: `Confirmacion de Registro - Chile Fintech Forum 2026 [${data.confirmation_number}]`,\n    email_body: emailBody\n  }\n};"
      },
