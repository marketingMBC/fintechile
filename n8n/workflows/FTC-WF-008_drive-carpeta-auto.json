      },
      "id": "drive-create-comunicaciones",
      "name": "Drive - Crear Subcarpeta Comunicaciones",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [
        1580,
        380
      ],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "gdrive-credentials",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "resource": "databasePage",
        "operation": "update",
        "pageId": {
