    {
      "parameters": {
        "content": "## Flujo Principal\n\nPara cada empresa activa sin carpeta:\n1. Extrae RUT y Nombre Empresa\n2. Crea carpeta principal: {RUT}-{NombreEmpresa}\n3. Crea 3 subcarpetas en paralelo:\n   - Contratos\n   - Facturas\n   - Comunicaciones\n4. Actualiza Notion con link Drive\n5. Notifica por Slack",
        "height": 240,
        "width": 340,
        "color": 6
      },
      "id": "sticky-main-flow",
      "name": "Nota - Flujo Principal",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        1260,
        -120
      ]
    }
