      },
      "id": "notion-update-link",
      "name": "Notion - Actualizar Link Carpeta",
      "type": "n8n-nodes-base.notion",
      "typeVersion": 2.2,
      "position": [
        1840,
        220
      ],
      "credentials": {
        "notionApi": {
          "id": "notion-credentials",
          "name": "Notion account"
        }
      }
    },
    {
      "parameters": {
        "select": "channel",
        "channelId": {
          "__rl": true,
          "value": "={{ $env.SLACK_CHANNEL_OPS }}",
          "mode": "id"
        },
        "text": ":file_folder: *Carpeta Drive creada para {{ $('Code - Extraer RUT y Nombre').item.json.nombreEmpresa }}*\n\n*RUT:* {{ $('Code - Extraer RUT y Nombre').item.json.rut }}\n*Carpeta:* {{ $('Code - Extraer RUT y Nombre').item.json.folderName }}\n*Subcarpetas:* Contratos, Facturas, Comunicaciones\n*Link:* {{ $('Drive - Crear Carpeta Principal').item.json.webViewLink }}\n\nRegistro actualizado en Notion con el link de la carpeta.",
        "otherOptions": {
          "includeLinkToWorkflow": true
        }
      },
